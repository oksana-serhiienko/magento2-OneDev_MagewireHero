<!-- With AlpineJs and events -->
<div x-data x-init="
    window.addEventListener('magewire-test-messages', event => {
        const type = event.detail.type || 'success';
        const text = event.detail.message || 'Something happened';

        const container = document.querySelector('.messages');
        if (container) {
            container.innerHTML = `
                <div class='message message-${type} ${type}'>
                    <div data-ui-id='messages-message-${type}'>${text}</div>
                </div>
            `;
        }
    });
"></div>


